# 复制为 secrets.yaml（勿提交到 git）

wifi_ssid: "你的 Wi-Fi 名称"
wifi_password: "你的 Wi-Fi 密码"
# 在 ESPHome Dashboard → Configure → API 中生成（须为 base64 的 32 字节）
api_encryption_key: "REPLACE_WITH_DASHBOARD_API_KEY"
ota_password: "your-ota-password"

# 同城 PM2.5：Home Assistant 里已有空气质量传感器的 entity_id（见 README）
city_pm25_entity_id: "sensor.your_city_pm25"

# 室内 TVOC 等级（1–6），无硬件时在 HA 建 template sensor 亦可（选型见 docs/TVOC_SENSOR.md）
tvoc_entity_id: "sensor.your_tvoc_level"

# 背光日/夜（backlight_time.yaml）
latitude: "31.2304"
longitude: "121.4737"
